# ---------------------------------------------------------------------------
# Lily configuration — copy to `.env` and fill in. NEVER commit your real .env.
# ---------------------------------------------------------------------------

# Solana RPC endpoint. A public endpoint works for light use, but the on-chain
# gates (holder concentration, launch-txn counts) are rate-limit heavy — use a
# dedicated provider (Helius, Triton, QuickNode, etc.) for real workloads.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# PumpPortal data WebSocket. The public endpoint is free and needs no key.
# (An API key only matters for their trade-execution API, which Lily does NOT use.)
PUMPPORTAL_WS_URL=wss://pumpportal.fun/api/data

# Port the API server listens on (the UI proxies /api -> here). Hosts like
# Railway/Render set PORT automatically.
PORT=8787

# ---- Persistence (SQLite) -------------------------------------------------
DB_PATH=data/lily.db           # durable board + rolling history
HISTORY_INTERVAL_MS=60000      # how often to record a history row per coin
HISTORY_RETENTION_MS=172800000 # prune history older than this (48h)

# ---- Public API (all optional) -------------------------------------------
# Comma-separated keys. If empty, the API is open. If set, consumers must pass
# ?key=... or an "x-api-key" header.
LILY_API_KEYS=
RATE_LIMIT_PER_MIN=240         # per key (or per IP if no key) requests/min

# ---- Old pre-bond scanner -------------------------------------------------
# Surface an OLDER, still-unbonded coin when it suddenly takes fresh bids.
OLD_SCAN_INTERVAL_MS=60000     # how often to scan (60s)
OLD_MIN_AGE_MS=25200000        # "old" = created at least this long ago (7h)
OLD_ACTIVE_MS=3600000          # count bids within this trailing window (1h)
OLD_MIN_RECENT_TRADES=5        # need at least this many recent bids to surface
OLD_MAX_PER_SCAN=12            # cap promotions per scan

# Note: the new-pairs / pre-bond discovery is intentionally NOT part of this
# public repo, so it has no configuration here.

# ---- Bonded (postbond) ----------------------------------------------------
BONDED_TRACK_MS=3600000        # keep tracking a bonded coin for this long (60m)
BONDED_EARLY_WINDOW_MS=60000   # "early dump" measurement window (60s)
